{
  "name": "@chaq/desktop",
  "version": "0.1.0",
  "private": true,
  "description": "Chaq Agent-first desktop client",
  "author": "Chaq",
  "type": "module",
  "main": "out/main/index.js",
  "scripts": {
    "predev": "node ../../scripts/check-ports.js desktop 27337",
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "package": "node ../../scripts/ensure-electron-runtime.js && npm run build && node ../../scripts/run-electron-builder.js --dir -c.win.signAndEditExecutable=false",
    "package:preview": "node ../../scripts/package-preview-client.js",
    "dist": "node ../../scripts/ensure-electron-runtime.js && npm run build && node ../../scripts/run-electron-builder.js"
  },
  "dependencies": {
    "sql.js": "^1.12.0"
  },
  "devDependencies": {
    "@chaq/shared": "file:../../packages/shared",
    "@types/node": "^26.1.1",
    "@types/react": "^18.3.11",
    "@types/react-dom": "^18.3.1",
    "@types/sql.js": "^1.4.9",
    "@vitejs/plugin-react": "^5.2.0",
    "electron": "43.1.0",
    "electron-builder": "^26.15.3",
    "electron-vite": "^5.0.0",
    "lucide-react": "^0.468.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "typescript": "^5.9.3",
    "vite": "^7.3.6"
  },
  "build": {
    "appId": "app.chaq.desktop",
    "productName": "Chaq",
    "electronDist": "../../node_modules/electron/dist",
    "directories": {
      "output": "release"
    },
    "files": [
      "out/**/*",
      "package.json",
      "!node_modules/@chaq/shared/src{,/**/*}",
      "!node_modules/@chaq/shared/tsconfig.json",
      "!node_modules/sql.js/.devcontainer{,/**/*}",
      "!node_modules/sql.js/*.md",
      "!node_modules/sql.js/*.svg",
      "!node_modules/sql.js/.eslintrc.js",
      "!node_modules/sql.js/.jsdoc.config.json",
      "!node_modules/sql.js/.nojekyll",
      "!node_modules/sql.js/AUTHORS",
      "!node_modules/sql.js/eslint.config.cjs",
      "!node_modules/sql.js/dist/sql-asm*.js",
      "!node_modules/sql.js/dist/sql-wasm-browser*",
      "!node_modules/sql.js/dist/sql-wasm-debug*",
      "!node_modules/sql.js/dist/worker.*"
    ],
    "asarUnpack": []
  }
}
